# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here
MODEL=claude-3-5-haiku-20241022

# Optional: Adjust max tokens for conversation history
MAX_CONVERSATION_TOKENS=100000

# For calendar access
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Slack Bot Configuration (optional)
# Create a Slack app at https://api.slack.com/
# Enable Socket Mode to get the App Token (starts with xapp-)
# Install to workspace to get the Bot Token (starts with xoxb-)
# Get the Bot User ID from your Slack app's App Home page
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_BOT_USER_ID=U0123456789
